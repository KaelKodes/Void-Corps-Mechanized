; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Void Corps: Mechanize"
config/version="0.2.1"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameSession="*res://scripts/GameSession.cs"
NetSession="*res://scripts/net/NetSession.cs"
SfxService="*res://scripts/audio/SfxService.cs"
MusicService="*res://scripts/audio/MusicService.cs"
TextVoiceService="*res://scripts/audio/TextVoiceService.cs"
PartThumbnail="*res://scripts/ui/PartThumbnail.cs"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Mechanize"

